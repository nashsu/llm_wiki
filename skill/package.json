{
  "name": "llm-wiki-nashsu-skill",
  "version": "0.4.6-skill.1",
  "description": "nashsu/llm_wiki backend as Node.js CLI + MCP server (no Tauri/GUI)",
  "main": "dist/cli.js",
  "bin": {
    "llm-wiki": "dist/cli.js",
    "llm-wiki-mcp": "dist/mcp-server.js"
